    "bundle:eslint": "tsx scripts/bundle-eslint-server.ts",
    "make": "pnpm bundle:eslint && cross-env NODE_OPTIONS=--max-old-space-size=8192 dotenv -e ../../.env.prod -- electron-forge make",
    "package": "pnpm bundle:eslint && cross-env NODE_OPTIONS=--max-old-space-size=8192 dotenv -e ../../.env -- electron-forge package",
    "publish": "dotenv -e ../../.env -- electron-forge publish",
    "start": "pnpm typecheck && dotenv -e ../../.env.dev -- electron-forge start",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "clean-data": "tsx scripts/clean-data.ts",
    "clear-vite-cache": "tsx scripts/clear-vite-cache.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "concurrently -n ui,backend,preload,storybook -c blue,green,yellow,magenta \"tsc -p tsconfig.ui.json --noEmit\" \"tsc -p tsconfig.backend.json --noEmit\" \"tsc -p tsconfig.web-content-preload.json --noEmit\" \"tsc -p tsconfig.storybook.json --noEmit\""
  },
